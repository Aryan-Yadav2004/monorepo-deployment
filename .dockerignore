# ── node_modules (root + every workspace) ──────────────────────────────────────
node_modules
**/node_modules

# ── Build outputs ───────────────────────────────────────────────────────────────
**/.next
**/dist
**/build
**/.turbo

# ── Prisma: keep schema & migrations, skip generated client ────────────────────
**/prisma/generated

# ── Local / dev environment ─────────────────────────────────────────────────────
**/.env
**/.env.*
!**/.env.example

# ── Version control & editor metadata ──────────────────────────────────────────
.git
.gitignore
.gitattributes
.vscode
.idea

# ── Logs & temp files ───────────────────────────────────────────────────────────
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# ── OS noise ────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Docker files themselves (no need to copy them in) ──────────────────────────
**/Dockerfile*
**/.dockerignore
